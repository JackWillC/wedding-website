{
  "baseURL": "https://JackWillC.github.io/wedding-website",
  "languageCode": "en-us",
  "title": "Rachel & Jack's Wedding",
  "show_comments": false,
  "disableKinds": [
    "sitemap",
    "RSS"
  ],
  "markup": {
    "defaultMarkdownHandler": "goldmark",
    "goldmark": {
      "extensions": {
        "definitionList": true,
        "footnote": true,
        "linkify": true,
        "linkifyProtocol": "https",
        "strikethrough": true,
        "table": true,
        "taskList": true,
        "typographer": true
      },
      "parser": {
        "attribute": {
          "block": false,
          "title": true
        },
        "autoHeadingID": true,
        "autoHeadingIDType": "github"
      },
      "renderer": {
        "hardWraps": false,
        "unsafe": true,
        "xhtml": false
      }
    }
  },
  "params": {
    "background_image_1": static/image/engagement-rj-bartholdi-142,
    "background_image_2": static/image/engagement-rj-bartholdi-47(1),
    "background_image_3": static/image/engagement-rj-bartholdi-102(1)
  }
}
